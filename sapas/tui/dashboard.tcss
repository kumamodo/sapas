    border: none;
}

#net-manager-table > .datatable--header {
    background: $secondary;
    color: $foreground;
    text-style: bold;
}

#net-manager-status {
    height: 1;
    content-align: center middle;
    color: $warning;
    margin: 0;
    text-style: italic;
}

#net-manager-actions {
    layout: horizontal;
